<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ExamCare.App"
             RequestedThemeVariant="Default">

	<Application.Styles>
		<FluentTheme />

		<!-- 🔥 BẮT BUỘC: Style của LiveMarkdown -->
		<StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml"/>
	</Application.Styles>

	<!-- 🔥 BẮT BUỘC: Defaults -->
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://LiveMarkdown.Avalonia/Defaults.axaml"/>
			</ResourceDictionary.MergedDictionaries>

			<x:Double x:Key="FontSizeM">18</x:Double>
			<x:Double x:Key="FontSizeL">20</x:Double>
			<x:Double x:Key="FontSizeXl">24</x:Double>
			<x:Double x:Key="FontSize2Xl">28</x:Double>
			<x:Double x:Key="FontSize3Xl">32</x:Double>
		</ResourceDictionary>
	</Application.Resources>

</Application>