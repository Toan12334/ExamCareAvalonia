<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="using:ExamCare.ViewModels"
             xmlns:conv="using:ExamCare.Converters"
             xmlns:model="using:ExamCare.Models"
             xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ExamCare.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <UserControl.Resources>
        <conv:ImageUrlToBitmapConverter x:Key="ImgConverter"/>
    </UserControl.Resources>

	<UserControl.Styles>
		<Style Selector="TextBlock">
			<Setter Property="FontFamily" Value="Segoe UI"/>
		</Style>

		<Style Selector="TextBox">
			<Setter Property="FontFamily" Value="Segoe UI"/>
		</Style>

		<Style Selector="Button">
			<Setter Property="FontFamily" Value="Segoe UI"/>
		</Style>

		<Style Selector="Button.questionButton">
			<Setter Property="Width" Value="44"/>
			<Setter Property="Height" Value="44"/>
			<Setter Property="Margin" Value="6"/>
			<Setter Property="Background" Value="#FBCFE8"/>
			<Setter Property="Foreground" Value="Black"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>

		<Style Selector="Button.questionButton:pointerover">
			<Setter Property="Background" Value="#C4B5FD"/>
		</Style>

		<Style Selector="Border.card">
			<Setter Property="CornerRadius" Value="14"/>
			<Setter Property="Padding" Value="16"/>
			<Setter Property="Margin" Value="10"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#E5E7EB"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
	</UserControl.Styles>

    <Grid Background="#F8FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#4F46E5">
            <Grid ColumnDefinitions="*,Auto,Auto" Margin="20,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding ExamName}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding CountdownText, StringFormat='Thời gian: {0}'}"
                               Foreground="#E0E7FF"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#6366F1"
                        CornerRadius="10"
                        Padding="12,8"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                    <TextBlock Text="{Binding CurrentQuestionNumber, StringFormat='Câu {0}'}"
                               Foreground="White"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="260,*">
            <Border Grid.Column="0" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="0,1,1,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Danh sách câu hỏi"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="16,16,16,10"/>

                    <ScrollViewer Grid.Row="1" Margin="10">
                        <ItemsControl ItemsSource="{Binding QuestionNumbers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:Int32">
                                    <Button Classes="questionButton"
                                            Content="{Binding}"
                                            Command="{Binding $parent[UserControl].DataContext.ClickCommand}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="*,Auto">
                <ScrollViewer Margin="8">
                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <md:MarkdownRenderer MarkdownBuilder="{Binding SelectedQuestion.QuestionContentBuilder}" />

                            <ItemsControl ItemsSource="{Binding SelectedQuestion.Images}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="model:QuestionImage">
                                        <Border Background="#F9FAFB"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12"
                                                Margin="0,6,0,0">
                                            <Image Source="{Binding ImageUrl, Converter={StaticResource ImgConverter}}"
                                                   Height="220"
                                                   Stretch="Uniform"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding SelectedQuestion.Options}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="model:QuestionOption">
                                        <Border Background="#F8FAFC"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14"
                                                Margin="0,6,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <RadioButton GroupName="QuestionOptions"
                                                             IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                             Command="{Binding $parent[UserControl].DataContext.SelectOptionCommand}"
                                                             CommandParameter="{Binding}" />
                                                <TextBlock Text="{Binding OptionLabel}"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                                <md:MarkdownRenderer MarkdownBuilder="{Binding OptionContentBuilder}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding SelectedQuestion.TrueFalseStatements}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="model:TrueFalseStatement">
                                        <Border Background="#FFF7ED"
                                                BorderBrush="#FED7AA"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14"
                                                Margin="0,6,0,0">
                                            <StackPanel Spacing="10">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding StatementLabel}"
                                                               FontWeight="Bold"
                                                               VerticalAlignment="Top"/>
                                                    <md:MarkdownRenderer MarkdownBuilder="{Binding StatementContentBuilder}" />
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Spacing="20">
                                                    <RadioButton Content="Đúng"
                                                                 GroupName="{Binding StatementId}"
                                                                 IsChecked="{Binding IsTrueSelected, Mode=TwoWay}"
                                                                 Command="{Binding $parent[UserControl].DataContext.SelectTrueStatementCommand}"
                                                                 CommandParameter="{Binding}" />

                                                    <RadioButton Content="Sai"
                                                                 GroupName="{Binding StatementId}"
                                                                 IsChecked="{Binding IsFalseSelected, Mode=TwoWay}"
                                                                 Command="{Binding $parent[UserControl].DataContext.SelectFalseStatementCommand}"
                                                                 CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel IsVisible="{Binding SelectedQuestion.IsType3}">
                                <Border Background="#F8FAFC"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14"
                                        Margin="0,6,0,0">
                                    <TextBox Text="{Binding SelectedQuestion.StudentAnswerText, Mode=TwoWay}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="120"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <Border Grid.Row="1"
                        Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1,1,0,0"
                        Padding="16">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" VerticalAlignment="Center">
                        <Button Content="Câu trước"
                                Command="{Binding PreviousQuestionCommand}"
                                Width="110"
                                Height="42"/>

                        <Button Grid.Column="1"
                                Content="Câu tiếp"
                                Command="{Binding NextQuestionCommand}"
                                Width="110"
                                Height="42"
                                Margin="10,0,0,0"/>

                        <Button Grid.Column="3"
                                Content="Nộp bài"
                                Command="{Binding SubmitCommand}"
                                Width="120"
                                Height="42"
                                Background="#EF4444"
                                Foreground="White"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>